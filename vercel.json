{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "apps/web/out",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/what", "destination": "/blogs/what-is-possible", "permanent": true },
    { "source": "/why", "destination": "/blogs/why-possible", "permanent": true }
  ]
}
