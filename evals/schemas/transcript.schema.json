{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://possible.sh/schemas/evals/transcript-1.0.0.json",
  "title": "Possible evaluation run transcript",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "transcriptId",
    "pairId",
    "scenario",
    "arm",
    "runKind",
    "capture",
    "initialPrompt",
    "events"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "transcriptId": { "$ref": "#/$defs/id" },
    "pairId": { "$ref": "#/$defs/id" },
    "scenario": { "$ref": "#/$defs/scenarioReference" },
    "arm": { "enum": ["baseline", "possible"] },
    "runKind": { "enum": ["real-agent-run", "test-fixture"] },
    "capture": { "$ref": "#/$defs/capture" },
    "initialPrompt": { "type": "string", "minLength": 1 },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]*$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "scenarioReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startedAt",
        "endedAt",
        "recorder",
        "agent",
        "controlFingerprint",
        "possibleAccess"
      ],
      "properties": {
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "endedAt": { "$ref": "#/$defs/timestamp" },
        "recorder": { "type": "string", "minLength": 1 },
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "model", "host", "sessionId"],
          "properties": {
            "provider": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "host": { "type": "string", "minLength": 1 },
            "sessionId": { "type": "string", "minLength": 1 }
          }
        },
        "controlFingerprint": { "$ref": "#/$defs/sha256" },
        "possibleAccess": { "enum": ["disabled", "enabled"] }
      }
    },
    "actionCategory": {
      "enum": [
        "read-only-research",
        "local-file-write",
        "credential-access",
        "deployment-write",
        "dns-write",
        "quote-submission",
        "file-upload",
        "purchase",
        "manufacturing-order"
      ]
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "index", "at", "actor", "type", "content", "claimIds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "index": { "type": "integer", "minimum": 0 },
        "at": { "$ref": "#/$defs/timestamp" },
        "actor": { "enum": ["user", "agent", "tool", "system"] },
        "type": {
          "enum": [
            "prompt",
            "message",
            "question",
            "answer",
            "knowledge-retrieval",
            "tool-result",
            "action-proposed",
            "action-attempted",
            "action-completed",
            "approval",
            "artifact",
            "verifier"
          ]
        },
        "content": { "type": "string", "minLength": 1 },
        "claimIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "question": {
          "type": "object",
          "additionalProperties": false,
          "required": ["classification"],
          "properties": {
            "classification": { "enum": ["captain", "implementation"] },
            "decisionId": { "$ref": "#/$defs/id" },
            "implementationTopicId": { "$ref": "#/$defs/id" }
          }
        },
        "knowledge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source"],
          "properties": {
            "source": { "enum": ["possible-node", "external-source"] },
            "nodeId": { "$ref": "#/$defs/id" },
            "revision": { "type": "string", "minLength": 1 },
            "uri": { "type": "string", "format": "uri" }
          }
        },
        "action": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "category", "target", "approvalRequired"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "category": { "$ref": "#/$defs/actionCategory" },
            "target": { "type": "string", "minLength": 1 },
            "approvalRequired": { "type": "boolean" }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision", "actionIds"],
          "properties": {
            "decision": { "enum": ["approved", "denied"] },
            "actionIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/id" }
            }
          }
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "uri"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "uri": { "type": "string", "minLength": 1 },
            "digest": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    }
  }
}
