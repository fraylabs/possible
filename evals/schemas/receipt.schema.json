{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://possible.sh/schemas/evals/receipt-1.0.0.json",
  "title": "Possible evaluation adjudication receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "receiptId",
    "pairId",
    "scenario",
    "arm",
    "runKind",
    "transcript",
    "adjudication"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "receiptId": { "$ref": "#/$defs/id" },
    "pairId": { "$ref": "#/$defs/id" },
    "scenario": { "$ref": "#/$defs/scenarioReference" },
    "arm": { "enum": ["baseline", "possible"] },
    "runKind": { "enum": ["real-agent-run", "test-fixture"] },
    "transcript": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "digest"],
      "properties": {
        "file": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*\\.transcript\\.json$"
        },
        "digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "adjudication": { "$ref": "#/$defs/adjudication" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]*$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "scenarioReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "eventId",
        "text",
        "category",
        "material",
        "constraintIds",
        "evidenceEventIds"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "eventId": { "$ref": "#/$defs/id" },
        "text": { "type": "string", "minLength": 1 },
        "category": {
          "enum": ["factual", "recommendation", "tool-fit", "provider-capability", "safety"]
        },
        "material": { "type": "boolean" },
        "constraintIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "evidenceEventIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "constraintAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraintId", "status", "evidenceEventIds", "notes"],
      "properties": {
        "constraintId": { "$ref": "#/$defs/id" },
        "status": { "enum": ["satisfied", "violated", "unknown"] },
        "evidenceEventIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "knowledgeUse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirementId",
        "retrievalEventId",
        "applicationEventId",
        "constraintIds"
      ],
      "properties": {
        "requirementId": { "$ref": "#/$defs/id" },
        "retrievalEventId": { "$ref": "#/$defs/id" },
        "applicationEventId": { "$ref": "#/$defs/id" },
        "constraintIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "questionAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "classification", "rationale"],
      "properties": {
        "eventId": { "$ref": "#/$defs/id" },
        "classification": { "enum": ["captain", "implementation"] },
        "decisionId": { "$ref": "#/$defs/id" },
        "implementationTopicId": { "$ref": "#/$defs/id" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "actionAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "category", "approvalRequired", "rationale"],
      "properties": {
        "actionId": { "$ref": "#/$defs/id" },
        "category": {
          "enum": [
            "read-only-research",
            "local-file-write",
            "credential-access",
            "deployment-write",
            "dns-write",
            "quote-submission",
            "file-upload",
            "purchase",
            "manufacturing-order"
          ]
        },
        "approvalRequired": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "adjudication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer",
        "completedAt",
        "coverage",
        "claims",
        "constraintAssessments",
        "knowledgeUses",
        "questionAssessments",
        "actionAssessments"
      ],
      "properties": {
        "reviewer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": { "enum": ["human", "independent-agent"] },
            "id": { "type": "string", "minLength": 1 }
          }
        },
        "completedAt": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allMaterialClaimsAnnotated",
            "allConstraintsAssessed",
            "allQuestionsClassified",
            "allActionsAssessed"
          ],
          "properties": {
            "allMaterialClaimsAnnotated": { "const": true },
            "allConstraintsAssessed": { "const": true },
            "allQuestionsClassified": { "const": true },
            "allActionsAssessed": { "const": true }
          }
        },
        "claims": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "constraintAssessments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/constraintAssessment" }
        },
        "knowledgeUses": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledgeUse" }
        },
        "questionAssessments": {
          "type": "array",
          "items": { "$ref": "#/$defs/questionAssessment" }
        },
        "actionAssessments": {
          "type": "array",
          "items": { "$ref": "#/$defs/actionAssessment" }
        }
      }
    }
  }
}
