{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://possible.sh/schemas/evals/report-1.0.0.json",
  "title": "Possible deterministic evaluation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "scenarioSet",
    "runPolicy",
    "sourceFiles",
    "pendingScenarioIds",
    "pairs"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "status": { "enum": ["pending-real-runs", "scored"] },
    "scenarioSet": { "type": "object" },
    "runPolicy": { "type": "object" },
    "sourceFiles": { "type": "array" },
    "pendingScenarioIds": { "type": "array", "items": { "type": "string" } },
    "pairs": { "type": "array" }
  }
}
