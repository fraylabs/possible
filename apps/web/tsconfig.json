{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.cache/possible-web.tsbuildinfo",
    "types": ["vite/client", "vitest/globals", "node"]
  },
  "include": ["src/App.tsx", "src/main.tsx", "vite.config.ts"]
}
