{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Possible outcome-v1 benchmark result",
  "type": "object",
  "required": [
    "runId",
    "condition",
    "taskId",
    "outputPath",
    "dispatchAt",
    "completedAt",
    "elapsedSeconds",
    "operatorFollowups",
    "operatorWords",
    "approvals",
    "isolation",
    "commands",
    "checks",
    "conditionCompliance",
    "decision"
  ],
  "properties": {
    "runId": { "type": "string" },
    "condition": { "enum": ["direct", "spec", "plan", "goal", "possible"] },
    "taskId": { "type": "string" },
    "outputPath": { "type": "string" },
    "dispatchAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "elapsedSeconds": { "type": "integer", "minimum": 0 },
    "operatorFollowups": { "type": "integer", "minimum": 0 },
    "operatorWords": { "type": "integer", "minimum": 0 },
    "approvals": { "type": "integer", "minimum": 0 },
    "isolation": {
      "type": "object",
      "required": ["status", "evidence"],
      "properties": {
        "status": { "enum": ["pass", "fail", "unproven"] },
        "evidence": { "type": "string" }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "exitCode", "summary"],
        "properties": {
          "command": { "type": "string" },
          "exitCode": { "type": "integer" },
          "summary": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["pass", "fail", "skipped", "unproven"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "conditionCompliance": {
      "type": "object",
      "required": ["status", "evidence"],
      "properties": {
        "status": { "enum": ["pass", "fail", "unproven"] },
        "evidence": { "type": "string" }
      }
    },
    "decision": { "enum": ["verified", "not_verified"] },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
